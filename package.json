{
  "name": "context-cache",
  "version": "0.1.0",
  "description": "Blazing-fast global context cache for AI prompts — Rust core, TS surface",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "context-cache": "dist/bin/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/context-cache"
  },
  "scripts": {
    "build:rs": "cargo build --release --manifest-path src/lib/rust/Cargo.toml",
    "copy:node": "node scripts/copy-binding.js",
    "build:native": "napi build --platform --release --manifest-path src/lib/rust/Cargo.toml --output-dir .",
    "build:ts": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome lint . --error-on-warnings",
    "lint:fix": "biome check . --write",
    "format:check": "biome format .",
    "format:write": "biome format . --write",
    "build": "npm run build:rs && npm run copy:node && npm run build:ts",
    "artifacts": "napi artifacts",
    "prepublish:napi": "napi prepublish -t npm",
    "test": "npm run build && node --test tests/*.test.js",
    "rust:fmt": "cargo fmt --manifest-path src/lib/rust/Cargo.toml --all",
    "rust:fmt:check": "cargo fmt --manifest-path src/lib/rust/Cargo.toml --all --check",
    "rust:clippy": "cargo clippy --manifest-path src/lib/rust/Cargo.toml --all-targets --all-features -- -D warnings",
    "rust:lint": "npm run rust:fmt:check && npm run rust:clippy",
    "prepare": "husky",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run rust:lint && npm test",
    "prepublishOnly": "npm run build && npm run prepublish:napi"
  },
  "napi": {
    "name": "context-cache",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-gnu",
        "x86_64-unknown-linux-musl",
        "x86_64-pc-windows-msvc",
        "aarch64-pc-windows-msvc"
      ]
    }
  },
  "files": ["dist", "binding.node", "npm"],
  "dependencies": {
    "commander": "^12.0.0"
  },
  "optionalDependencies": {
    "context-cache-darwin-arm64": "0.1.0",
    "context-cache-darwin-x64": "0.1.0",
    "context-cache-linux-arm64-gnu": "0.1.0",
    "context-cache-linux-x64-gnu": "0.1.0",
    "context-cache-linux-x64-musl": "0.1.0",
    "context-cache-win32-arm64-msvc": "0.1.0",
    "context-cache-win32-x64-msvc": "0.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{ts,tsx,js,cjs,mjs,json}": ["biome check --write"],
    "*.rs": ["rustfmt --edition 2024"]
  }
}
